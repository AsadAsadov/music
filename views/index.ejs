<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Musiqi Axtarış Paneli</title>
    <style>
        :root { --bg: #0d1117; --card-bg: rgba(22, 27, 34, 0.8); --text: #c9d1d9; --accent: #58a6ff; --green: #2ea44f; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); margin: 0; padding: 10px; font-size: 11px; }
        
        /* Navbar */
        .navbar { display: flex; justify-content: space-between; align-items: center; background: var(--card-bg); padding: 6px 12px; border-radius: 6px; border: 1px solid #30363d; margin-bottom: 8px; }
        .brand { font-size: 12px; font-weight: bold; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 4px; }
        .search-form { display: flex; gap: 4px; }
        input[type="text"], textarea { background: #161b22; border: 1px solid #30363d; color: #fff; padding: 4px 8px; font-size: 11px; border-radius: 4px; width: 130px; box-sizing: border-box; }
        textarea { width: 100%; height: 70px; resize: none; margin-bottom: 6px; font-family: inherit; }
        button { background: var(--accent); color: white; border: none; padding: 4px 10px; font-size: 11px; border-radius: 4px; cursor: pointer; font-weight: bold; }
        .btn-add { background: var(--green); }
        .btn-back { background: #21262d; border: 1px solid #30363d; color: var(--text); text-decoration: none; padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; display: none; }

        /* Grid Layout */
        .main-container { display: grid; grid-template-columns: 1fr; gap: 10px; }
        .panel-box { background: var(--card-bg); border: 1px solid #30363d; border-radius: 6px; padding: 8px; }
        .section-title { font-size: 11px; margin: 0 0 6px 0; color: #8b949e; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; display: flex; justify-content: space-between; align-items: center; }

        /* Artist Siyahısı və Aktivlik Nöqtələri */
        .artist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(105px, 1fr)); gap: 4px; max-height: 83vh; overflow-y: auto; padding-right: 4px; }
        .artist-card { background: #161b22; border: 1px solid #21262d; padding: 5px 6px; border-radius: 4px; text-decoration: none; color: var(--text); display: flex; flex-direction: column; justify-content: center; min-height: 34px; transition: 0.15s; box-sizing: border-box; position: relative; }
        .artist-card:hover, .artist-card.active { border-color: var(--accent); background: #1f242c; }
        .artist-name { font-weight: bold; color: #fff; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; width: 85%; }
        .artist-count { color: #8b949e; font-size: 9px; margin-top: 1px; }
        
        /* GitHub Stilində Aktivlik Nöqtəsi */
        .activity-dot { position: absolute; top: 6px; right: 6px; width: 6px; height: 6px; border-radius: 50%; background: #161b22; }
        .dot-low { background: #0e4429; }      /* 1-2 mahnı (Tünd yaşıl) */
        .dot-medium { background: #006d32; }   /* 3-5 mahnı (Orta yaşıl) */
        .dot-high { background: #26a641; }     /* 6-10 mahnı (Parlaq yaşıl) */
        .dot-viral { background: #39d353; box-shadow: 0 0 4px #39d353; } /* 10+ mahnı (Super trend) */

        /* Mahnı Kartları */
        .song-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 6px; max-height: 77vh; overflow-y: auto; padding-right: 4px; }
        .song-card { background: linear-gradient(145deg, #1f242c, #161b22); border: 1px solid #30363d; border-left: 3px solid var(--accent); padding: 8px; border-radius: 5px; box-shadow: 0 2px 5px rgba(0,0,0,0.2); display: flex; flex-direction: column; justify-content: space-between; min-height: 52px; position: relative; transition: opacity 0.15s; }
        .song-info-click { cursor: pointer; flex-grow: 1; width: 80%; }
        .song-title { font-size: 11px; font-weight: bold; color: #fff; margin-bottom: 2px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .song-artist { color: #8b949e; font-size: 10px; margin-bottom: 4px; }
        .song-hashtag { color: #58a6ff; font-style: italic; font-size: 9px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        
        /* Sağ Üst Kompakt Düymələr */
        .card-actions-wrapper { position: absolute; top: 4px; right: 4px; display: flex; gap: 3px; z-index: 5; }
        .btn-mini { background: rgba(48, 54, 61, 0.6); border: 1px solid #30363d; border-radius: 4px; padding: 2px 4px; font-size: 9px; color: #8b949e; cursor: pointer; transition: 0.15s; }
        .btn-mini:hover { color: #fff; background: #161b22; }
        .btn-mini.edit:hover { color: var(--accent); border-color: var(--accent); }
        .btn-mini.copy:hover { color: var(--green); border-color: var(--green); }

        /* Anlıq Filtr İonputu */
        .live-filter-box { width: 100%; margin-bottom: 8px; background: #0d1117; border: 1px solid #30363d; padding: 5px 8px; font-size: 11px; color: #fff; border-radius: 4px; box-sizing: border-box; }
        .live-filter-box::placeholder { color: #8b949e; font-style: italic; }

        /* Modallar */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); justify-content: center; align-items: center; z-index: 100; padding: 10px; box-sizing: border-box; }
        .modal-content { background: #161b22; border: 1px solid #30363d; padding: 12px; border-radius: 6px; width: 100%; max-width: 290px; box-sizing: border-box; }
        .modal-content h3 { margin-top: 0; color: #fff; font-size: 12px; margin-bottom: 8px; border-bottom: 1px solid #30363d; padding-bottom: 4px; }
        .modal-content input { width: 100%; margin-bottom: 6px; display: block; padding: 5px; background: #0d1117; border: 1px solid #30363d; color: #fff; border-radius: 4px; font-size: 11px; box-sizing: border-box; }
        .modal-actions { display: flex; justify-content: flex-end; gap: 4px; margin-top: 8px; }

        .lyrics-text { font-size: 11px; color: #c9d1d9; max-height: 230px; overflow-y: auto; white-space: pre-wrap; background: #0d1117; padding: 8px; border-radius: 4px; border: 1px solid #30363d; line-height: 1.5; text-align: center; }

        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #0d1117; }
        ::-webkit-scrollbar-thumb { background: #30363d; border-radius: 2px; }

        /* Notification Toast */
        .toast { position: fixed; bottom: 15px; right: 15px; background: var(--green); color: white; padding: 6px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; display: none; z-index: 200; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }

        @media (min-width: 768px) {
            .main-container { grid-template-columns: 360px 1fr; align-items: start; }
            .left-box, .right-box { display: block !important; }
        }
        @media (max-width: 767px) {
            input[type="text"] { width: 100px; }
            .brand span { display: none; }
            <% if (selectedArtist) { %>
                .left-box { display: none !important; }
                .right-box { display: block !important; }
                .btn-back { display: inline-block; margin-right: 6px; }
            <% } else { %>
                .left-box { display: block !important; }
                .right-box { display: none !important; }
            <% } %>
        }
    </style>
</head>
<body>

    <div id="toastNotification" class="toast">📋 Mahnı sözləri və hashtag kopyalandı!</div>

    <div class="navbar">
        <div style="display: flex; align-items: center;">
            <a href="/" class="btn-back">⬅ Geri</a>
            <a href="/" class="brand">🎵 <span>Selnet Music</span></a>
        </div>
        <div style="display: flex; gap: 4px;">
            <form action="/search" method="GET" class="search-form">
                <input type="text" name="search" value="<%= searchWord %>" placeholder="Artist və ya mahnı..." autocomplete="off">
                <button type="submit">Ara</button>
            </form>
            <button class="btn-add" onclick="openModal('addModal')">+ Əlavə Et</button>
        </div>
    </div>

    <div class="main-container">
        
        <div class="panel-box left-box">
            <div class="section-title">Bütün Artistlər (<%= artists.length %>)</div>
            <div class="artist-grid">
                <% artists.forEach(art => { 
                    let dotClass = 'dot-low';
                    if (art.count >= 10) { dotClass = 'dot-viral'; }
                    else if (art.count >= 6) { dotClass = 'dot-high'; }
                    else if (art.count >= 3) { dotClass = 'dot-medium'; }
                %>
                    <a href="/search?search=<%= encodeURIComponent(art.name) %>" class="artist-card <%= selectedArtist.toLowerCase() === art.name.toLowerCase() ? 'active' : '' %>">
                        <span class="artist-name"><%= art.name %></span>
                        <span class="artist-count">🎵 <%= art.count %> mahnı</span>
                        <div class="activity-dot <%= dotClass %>" title="<%= art.count %> mahnı"></div>
                    </a>
                <% }) %>
            </div>
        </div>

        <div class="panel-box right-box">
            <% if (selectedArtist) { %>
                <div class="section-title" style="color: #fff; border-bottom: 1px solid #21262d; padding-bottom: 4px; margin-bottom: 6px;">
                    <span>🔍 Nəticələr: <%= selectedArtist %> (<span id="visibleCount"><%= artistSongs.length %></span>)</span>
                </div>
                
                <input type="text" id="liveSearchInput" class="live-filter-box" placeholder="Bu siyahıda anlıq axtar (mahnı adı və ya hashtag)..." oninput="filterSongs()" autocomplete="off">

                <div class="song-container" id="songContainer">
                    <% if (artistSongs.length > 0) { %>
                        <% artistSongs.forEach(song => { %>
                            <div class="song-card" data-song-id="<%= song.id %>">
                                
                                <div class="song-info-click" onclick="viewLyrics('<%= song.id %>')">
                                    <div class="song-title" title="<%= song.song %>"><%= song.song %></div>
                                    <div class="song-artist">🎤 <%= song.artist %></div>
                                    <div class="song-hashtag" title="<%= song.hashtag %>"><%= song.hashtag || '#yoxdur' %></div>
                                </div>
                                
                                <div class="card-actions-wrapper">
                                    <button class="btn-mini copy" onclick="copyLyricsFromCard('<%= song.id %>')" title="Sözləri sürətli kopyala">📋</button>
                                    <button class="btn-mini edit" onclick="openEditModal('<%= song.id %>')" title="Redaktə et və ya sil">✏️</button>
                                </div>
                                
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div style="color: #f85149; padding: 5px; grid-column: 1/-1;">Heç bir nəticə tapılmadı.</div>
                    <% } %>
                </div>
            <% } else { %>
                <div style="color: #8b949e; text-align: center; padding-top: 60px; font-size: 11px;">
                    Müğənni/mahnı seçin və ya yuxarıdan axtarış edin.
                </div>
            <% } %>
        </div>
    </div>

    <div id="addModal" class="modal">
        <div class="modal-content">
            <h3>🎵 Yeni Mahnı Əlavə Et</h3>
            <form action="/add-song" method="POST">
                <input type="text" name="artist" placeholder="Müğənni adı" required>
                <input type="text" name="song" placeholder="Mahnı adı" required>
                <input type="text" name="hashtag" placeholder="#hashtag">
                <textarea name="lyrics" placeholder="Mahnı sözləri..."></textarea>
                <div class="modal-actions">
                    <button type="button" style="background: #da3637;" onclick="closeModal('addModal')">Ləğv et</button>
                    <button type="submit">Yadda saxla</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editModal" class="modal">
        <div class="modal-content">
            <h3>✏️ Mahnını Redaktə Et / Sil</h3>
            
            <form action="/edit-song" method="POST" id="mainEditForm">
                <input type="hidden" name="id" id="editId">
                <input type="text" name="artist" id="editArtist" placeholder="Müğənni adı" required>
                <input type="text" name="song" id="editSong" placeholder="Mahnı adı" required>
                <input type="text" name="hashtag" id="editHashtag" placeholder="#hashtag">
                <textarea name="lyrics" id="editLyrics" placeholder="Mahnı sözləri..."></textarea>
            </form>

            <div class="modal-actions" style="display: flex; justify-content: space-between; margin-top: 10px;">
                <form action="/delete-song" method="POST" onsubmit="return confirm('Bu mahnını silmək istədiyinizdən əminsiniz?');">
                    <input type="hidden" name="id" id="deleteId">
                    <input type="hidden" name="artist" id="deleteArtist">
                    <button type="submit" style="background: #da3637;">🗑️ Sil</button>
                </form>

                <div style="display: flex; gap: 4px;">
                    <button type="button" style="background: #21262d; border: 1px solid #30363d;" onclick="closeModal('editModal')">Geri</button>
                    <button type="button" style="background: var(--green);" onclick="document.getElementById('mainEditForm').submit();">Yenilə</button>
                </div>
            </div>
        </div>
    </div>

    <div id="lyricsModal" class="modal">
        <div class="modal-content" style="max-width: 320px;">
            <h3 id="lyricsTitle">Mahnı Sözləri</h3>
            <div id="lyricsBody" class="lyrics-text"></div>
            <div class="modal-actions">
                <button type="button" style="background: #21262d; border: 1px solid #30363d;" onclick="closeModal('lyricsModal')">Bağla</button>
            </div>
        </div>
    </div>

    <script>
        // Təhlükəsiz massiv
        const clientSongsArray = <%- JSON.stringify(artistSongs) %>;

        function openModal(id) { document.getElementById(id).style.display = 'flex'; }
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        // Sözləri ekranda göstərmək
        function viewLyrics(songId) {
            const found = clientSongsArray.find(s => String(s.id) === String(songId));
            if(found) {
                document.getElementById('lyricsTitle').innerText = found.artist + " - " + found.song;
                document.getElementById('lyricsBody').innerText = found.lyrics && found.lyrics.trim() !== "" ? found.lyrics.trim() : "Sözlər əlavə edilməyib.";
                openModal('lyricsModal');
            }
        }

        // Redaktə modalını açmaq
        function openEditModal(songId) {
            const found = clientSongsArray.find(s => String(s.id) === String(songId));
            if(found) {
                document.getElementById('editId').value = found.id;
                document.getElementById('editArtist').value = found.artist || '';
                document.getElementById('editSong').value = found.song || '';
                document.getElementById('editHashtag').value = found.hashtag || '';
                document.getElementById('editLyrics').value = found.lyrics || '';

                document.getElementById('deleteId').value = found.id;
                document.getElementById('deleteArtist').value = found.artist || '';

                openModal('editModal');
            }
        }

        // YENİ: Düyməyə basanda sözləri və hashtagı saniyəsində kopyalayan funksiya
        function copyLyricsFromCard(songId) {
            const found = clientSongsArray.find(s => String(s.id) === String(songId));
            if(found) {
                const hashtags = found.hashtag ? found.hashtag.trim() : '';
                const lyrics = found.lyrics ? found.lyrics.trim() : '';
                
                // Kopyalanacaq mətni formalaşdırırıq
                const fullText = (lyrics + "\n\n" + hashtags).trim();
                
                if (fullText !== "") {
                    navigator.clipboard.writeText(fullText).then(() => {
                        // Toast bildirişini göstər
                        const toast = document.getElementById('toastNotification');
                        toast.style.display = 'block';
                        setTimeout(() => { toast.style.display = 'none'; }, 2000);
                    }).catch(err => {
                        console.error('Kopyalama xətası:', err);
                    });
                }
            }
        }

        // YENİ: Səhifəni yeniləmədən sağ paneldə anlıq axtarış funksiyası (Live Filter)
        function filterSongs() {
            const query = document.getElementById('liveSearchInput').value.toLowerCase().trim();
            const songCards = document.querySelectorAll('.song-container .song-card');
            let visibleCounter = 0;

            songCards.forEach(card => {
                const songId = card.getAttribute('data-song-id');
                const found = clientSongsArray.find(s => String(s.id) === String(songId));
                
                if(found) {
                    const songName = (found.song || '').toLowerCase();
                    const hashtag = (found.hashtag || '').toLowerCase();
                    
                    // Mahnı adı və ya hashtag uyğun gəlirsə göstər, gəlmirsə gizlə
                    if(songName.includes(query) || hashtag.includes(query)) {
                        card.style.display = 'flex';
                        visibleCounter++;
                    } else {
                        card.style.display = 'none';
                    }
                }
            });

            // Başlıqdakı mahnı sayını anlıq yeniləyirik
            const countElem = document.getElementById('visibleCount');
            if(countElem) countElem.innerText = visibleCounter;
        }
    </script>
</body>
</html>
